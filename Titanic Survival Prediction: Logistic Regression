d','Teen','YoungAdult','Adult','Senior'])\n    \n    return df\n\n# apply ke train & test\ntrain_clean = preprocess(train)\ntest_clean = preprocess(test)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-21T05:35:31.986844Z","iopub.execute_input":"2026-06-21T05:35:31.987204Z","iopub.status.idle":"2026-06-21T05:35:32.009707Z","shell.execute_reply.started":"2026-06-21T05:35:31.987175Z","shell.execute_reply":"2026-06-21T05:35:32.008822Z"}},"outputs":[],"execution_count":87},{"cell_type":"markdown","source":"## 5. Baseline Model — Logistic Regression","metadata":{}},{"cell_type":"code","source":"# ===== Pipeline Logistic Regression =====\nnum_features = ['Age','Fare','FamilySize']\ncat_features = ['Pclass','Sex','Embarked']\n\npreprocessor = ColumnTransformer(\n    transformers=[\n        ('num', StandardScaler(), num_features),\n        ('cat', OneHotEncoder(handle_unknown='ignore'), cat_features)\n    ])\n\npipeline = Pipeline(steps=[\n    ('preprocessor', preprocessor),\n    ('model', LogisticRegression(max_iter=1000, random_state=42))\n])\n\nX = train_clean.drop(columns=['Survived'])\ny = train_clean['Survived']\n\n# split dengan stratify\nX_train, X_val, y_train, y_val = train_test_split(\n    X, y, test_size=0.2, stratify=y, random_state=42\n)\n\npipeline.fit(X_train, y_train)\nval_preds = pipeline.predict(X_val)\n\nprint(\"Validation Accuracy:\", accuracy_score(y_val, val_preds))\n\n# cross-validation untuk hasil stabil\nscores = cross_val_score(pipeline, X, y, cv=5, scoring='accuracy')\nprint(\"Cross-validation Accuracy:\", scores.mean())","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-21T05:34:12.216417Z","iopub.execute_input":"2026-06-21T05:34:12.21675Z","iopub.status.idle":"2026-06-21T05:34:12.377162Z","shell.execute_reply.started":"2026-06-21T05:34:12.216725Z","shell.execute_reply":"2026-06-21T05:34:12.376526Z"}},"outputs":[{"name":"stdout","text":"Validation Accuracy: 0.8108108108108109\nCross-validation Accuracy: 0